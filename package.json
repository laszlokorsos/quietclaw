{
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "name": "quietclaw",
  "version": "0.1.0",
  "description": "The silent claw that listens — open-source meeting intelligence for the agentic stack",
  "main": "out/main/index.js",
  "author": "Laszlo Korsos",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/laszlokorsos/quietclaw.git"
  },
  "keywords": [
    "meeting-recording",
    "transcription",
    "speech-to-text",
    "electron",
    "macos",
    "deepgram",
    "ai-summarization",
    "claude",
    "agentic",
    "meeting-intelligence",
    "core-audio"
  ],
  "private": true,
  "scripts": {
    "rebuild:sqlite": "node -e \"const v = require('./node_modules/electron/package.json').version; const {execSync} = require('child_process'); execSync('cd ' + require.resolve('better-sqlite3/package.json').replace('/package.json','') + ' && npx prebuild-install --runtime electron --target ' + v + ' --arch ' + process.arch + ' --tag-prefix v', {stdio:'inherit'})\"",
    "predev": "pnpm run rebuild:sqlite",
    "dev": "electron-vite dev; stty sane 2>/dev/null; echo",
    "dev:app": "electron-vite build && open node_modules/electron/dist/Electron.app --args \"$PWD\"",
    "build": "electron-vite build && electron-builder",
    "build:vite": "electron-vite build",
    "build:native": "cd native && npx node-gyp rebuild",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "pretest": "node -e \"const {execSync} = require('child_process'); execSync('cd ' + require.resolve('better-sqlite3/package.json').replace('/package.json','') + ' && npx prebuild-install --tag-prefix v', {stdio:'inherit'})\"",
    "test": "vitest run",
    "posttest": "pnpm run rebuild:sqlite",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "pnpm run rebuild:sqlite"
  },
  "dependencies": {
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/oauth2": "^5.0.1",
    "better-sqlite3": "^11.7.0",
    "electron-log": "^5.2.4",
    "express": "^4.21.0",
    "toml": "^3.0.0",
    "uuid": "^10.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@deepgram/sdk": "^3.9.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "node-addon-api": "^8.3.0",
    "node-gyp": "^10.3.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
